# 7회차 Airflow + Glue + S3 시연용 환경 변수.
# `.env` 로 복사하여 본인 bucket 으로 채우세요. AWS 자격증명은 `~/.aws/credentials` 에 두면 됩니다.
#
#   cp .env.example .env
#   vi .env            # bucket / prefix 본인 값으로 변경
#   docker compose --profile airflow up -d --build

ICEBERG_CATALOG_NAME=glue_catalog
ICEBERG_WAREHOUSE=s3://<your-bucket>/<your-prefix>/warehouse
ICEBERG_DATABASE=ad_lakehouse
# raw zone 은 spark.read.format("parquet") 으로 읽으므로 Hadoop S3A 가 필요 → s3a:// 스킴.
# ICEBERG_WAREHOUSE 는 Iceberg 의 S3FileIO 가 처리하므로 s3:// 그대로 둔다.
ICEBERG_RAW_BASE=s3a://<your-bucket>/<your-prefix>/raw
